# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP settings for sending emails (e.g. Gmail)
SMTP_USER="facilitiesrisel@gmail.com"
SMTP_PASS="@Cap150957"

# Firebase Integration (Required for Cloud persistence on Render/Koyeb)
# Caso use o Firebase Firestore fora do Google Cloud (como no Render):
FIREBASE_PROJECT_ID="ai-studio-gestodechamadosf-7f52e822-8adb-43fa-b48c-7276f3a17ad7"
FIREBASE_FIRESTORE_DATABASE_ID="(default)"
# Cole o conteúdo do JSON da chave de conta de serviço (Service Account Key) em uma linha única, ou use como string
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", ...}'

